{
  "sourceLanguage" : "en",
  "strings" : {
    "--:--" : {
      "comment" : "A placeholder text for the hour and minute of a timestamp.",
      "isCommentAutoGenerated" : true
    },
    "%lld" : {
      "comment" : "A text label displaying a radar signal strength value in decibels-millibars (dBZ) and its corresponding wind speed in millimeters per hour (mm/h). The argument is the radar signal strength",
      "isCommentAutoGenerated" : true
    },
    "%lld min" : {
      "comment" : "A segmented control with options for selecting the time interval between radar image updates. Each segment label shows the number of minutes.",
      "isCommentAutoGenerated" : true
    },
    "%lld%%" : {
      "comment" : "A label displaying the current opacity of the radar overlay. The value is shown as a percentage.",
      "isCommentAutoGenerated" : true
    },
    "📱❤️⛈️" : {
      "comment" : "An emoji representation of a smartphone, a heart, and a cloud.",
      "isCommentAutoGenerated" : true
    },
    "about.data_source_description" : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Radarová data poskytuje Český hydrometeorologický ústav (ČHMÚ) pod licencí CC BY 4.0."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Radar data is provided by the Czech Hydrometeorological Institute (ČHMÚ) under CC BY 4.0 license."
