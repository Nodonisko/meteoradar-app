    "settings.image_quality_footer" : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Standartní kvalita je vhodná pro většinu uživatelů a nejrychlejší načítání. Vyšší kvalita zvýší velikost souborů o ~50% a rozdíl k kvalitě je jen nepatrný (jen pro ty co chtějí maximum detailů)."
