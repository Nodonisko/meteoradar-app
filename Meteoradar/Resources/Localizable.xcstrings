    "settings.image_quality_footer" : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Standartní kvalita je vhodná pro většinu uživatelů a nejrychlejší načítání. Vyšší kvalita zvýší velikost souborů o ~50% a rozdíl k kvalitě je jen nepatrný (jen pro ty co chtějí maximum detailů)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Standard quality is suitable for most users and the fastest loading. Higher quality increases file size by ~50% and the difference in quality is only slight (only for those who want maximum detail)."
          }
        }
      }
    },
