    "changelog.message" : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- Pokud vyrážíte na dovolenou do zahraničí, můžete si Meteoradar vzít s sebou. **Podporuje nyní až 29 zemí v Evropě.**\n- Přidáno tlačítko přesunutí na vaši současnou polohu\n- Nový ještě rychlejší server, díky kterému se snímky pro ČR objeví již pár vteřin po pořízení ČHMÚ"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- If you are heading abroad for vacation, you can take Meteoradar with you. It now supports up to 29 countries in Europe.\n- Added a button to move to your current location\n- A new, even faster server makes Czech radar images appear just a few seconds after CHMI captures them"
          }
        }
      }
    },
